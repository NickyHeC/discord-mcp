# Copy: cp .env.example .env
# See README.md and AUTHENTICATION.md.

# Dedalus (local / hosted)
DEDALUS_AS_URL=https://as.dedaluslabs.ai
DEDALUS_API_KEY=
DEDALUS_API_URL=https://api.dedaluslabs.ai

# Bot token — must match SecretKeys(token="...") in src/main.py (default: DISCORD_TOKEN)
DISCORD_TOKEN=

# Server bind (optional)
PORT=8080
HOST=0.0.0.0
